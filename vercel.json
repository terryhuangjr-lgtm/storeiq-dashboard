{
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "devCommand": "npm run dev",
  "framework": "vite",
  "env": {
    "VITE_SUPABASE_URL": {
      "description": "Supabase project URL",
      "required": false
    },
    "VITE_SUPABASE_ANON_KEY": {
      "description": "Supabase anon/public API key",
      "required": false
    }
  }
}